{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "CRAFTEL",
  "version": "0.1.2",
  "identifier": "dev.chanler.craftel",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "CRAFTEL",
        "width": 1200,
        "height": 800
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "app",
      "dmg"
    ],
    "category": "DeveloperTool",
    "shortDescription": "Local workspace for AI-assisted software development",
    "longDescription": "CRAFTEL is a local, project-oriented workspace for AI-assisted software development.",
    "icon": [
      "icons/icon.png"
    ],
    "macOS": {
      "minimumSystemVersion": "11.0"
    }
  }
}
